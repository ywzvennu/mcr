xiangqi rjoukuojr/9/1c5c1/z1z1z1z1z/9/9/Z1Z1Z1Z1Z/1C5C1/9/RJOUKUOJR w - - bm Ra2; D1 44; D2 1920; D3 79666; id "xq-startpos";
xiangqi r1oukuo1r/9/1cj3jc1/z1z1z1z1z/9/9/Z1Z1Z1Z1Z/1CJ3JC1/9/R1OUKUO1R w - - D1 36; D2 1292; id "xq-mid";
xiangqi rjoukuojr/9/4c4/z1z1C1z1z/9/9/Z1Z3Z1Z/1C5c1/9/RJOUKUOJR b - - D1 11; D2 373; id "xq-cannon-cap";

