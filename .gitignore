# Rust build artifacts
/target
**/*.rs.bk
*.pdb

# cargo-mutants mutation-testing output (report dir, regenerated on each run).
mutants.out/
mutants.out.old/

# Fuzzing
/fuzz/target
/fuzz/corpus
/fuzz/artifacts

# Benchmark comparison crate (links GPL shakmaty; never published)
/compare/target

# Fairy-Stockfish comparison crate (drives the GPL FSF binary as a subprocess
# ONLY — never links it; never published). Ignore its build artifacts and any
# cloned/compiled FSF binary (which must never be committed).
/compare-fairy/target
/compare-fairy/build

# Unified `mcr` CLI crate (separate nested crate; never published)
/cli/target

# WebAssembly bindings crate (separate, never published): build artifacts and
# the wasm-pack output package.
/bindings/wasm/target
/bindings/wasm/pkg
# C FFI binding crate (separate nested crate; never published)
/bindings/c/target
# Python bindings crate (pyo3): cargo target + Python build artifacts.
/bindings/python/target
/bindings/python/dist
**/__pycache__/
*.so
*.pyd
.pytest_cache/
*.egg-info/

# proptest failure-replay seeds: regenerated on demand, not part of the suite.
proptest-regressions/

# Editor / OS
.idea/
.vscode/
.DS_Store

